---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_PHONE, SITE_EMAIL, SITE_ADDRESS } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Contact | ${SITE_TITLE}`} description="Contact Dr. Taylor Stuteville at Slate Psychology in Overland Park, KS. Schedule a consultation for therapy services." />
	</head>
	<body>
		<Header />

		<section class="page-hero">
			<div class="container">
				<p class="section-label">Get in Touch</p>
				<h1>Contact Slate Psychology</h1>
				<p class="page-hero-desc">Take the first step toward the support you deserve.</p>
			</div>
		</section>

		<section class="section">
			<div class="container">
				<div class="contact-grid">
					<div class="contact-info">
						<h2>Reach Out</h2>
						<p>Whether you're ready to schedule or just have questions, we're here to help. All inquiries are confidential.</p>

						<div class="info-cards">
							<div class="info-card">
								<div class="info-icon">
									<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
								</div>
								<div>
									<strong>Phone</strong>
									<a href="tel:{SITE_PHONE}">{SITE_PHONE}</a>
								</div>
							</div>
							<div class="info-card">
								<div class="info-icon">
									<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
								</div>
								<div>
									<strong>Email</strong>
									<a href="mailto:{SITE_EMAIL}">{SITE_EMAIL}</a>
								</div>
							</div>
							<div class="info-card">
								<div class="info-icon">
									<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
								</div>
								<div>
									<strong>Office</strong>
									<p>{SITE_ADDRESS}</p>
								</div>
							</div>
						</div>

						<div class="office-hours">
							<h3>Office Hours</h3>
							<div class="hours-grid">
								<span>Monday &ndash; Thursday</span><span>9:00 AM &ndash; 5:00 PM</span>
								<span>Friday</span><span>9:00 AM &ndash; 3:00 PM</span>
								<span>Saturday &ndash; Sunday</span><span>Closed</span>
							</div>
							<p class="hours-note">Hours are approximate. Please call or email to confirm availability.</p>
						</div>
					</div>

					<div class="contact-form-wrap">
						<div class="form-card">
							<h3>Send a Message</h3>
							<p class="form-note">All communications are confidential. We'll respond within one business day.</p>
							<form class="contact-form">
								<div class="form-group">
									<label for="name">Full Name</label>
									<input type="text" id="name" name="name" placeholder="Your name" required />
								</div>
								<div class="form-row">
									<div class="form-group">
										<label for="email">Email</label>
										<input type="email" id="email" name="email" placeholder="your@email.com" required />
									</div>
									<div class="form-group">
										<label for="phone">Phone</label>
										<input type="tel" id="phone" name="phone" placeholder="(555) 123-4567" />
									</div>
								</div>
								<div class="form-group">
									<label for="interest">I'm Interested In</label>
									<select id="interest" name="interest">
										<option value="">Select a service...</option>
										<option value="first-responder">First Responder Therapy</option>
										<option value="anxiety-depression">Anxiety & Depression</option>
										<option value="chronic-pain">Chronic Pain Psychology</option>
										<option value="stress">Stress Management</option>
										<option value="child-adolescent">Child & Adolescent Services</option>
										<option value="other">Other / Not Sure</option>
									</select>
								</div>
								<div class="form-group">
									<label for="message">Message</label>
									<textarea id="message" name="message" rows="4" placeholder="Tell us a bit about what you're looking for..."></textarea>
								</div>
								<button type="submit" class="btn btn-primary" style="width: 100%;">Send Message</button>
							</form>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Map placeholder -->
		<section class="map-section">
			<div class="map-placeholder">
				<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
					<circle cx="12" cy="10" r="3"/>
				</svg>
				<p>Map Placeholder &mdash; 9200 Indian Creek Pkwy, Suite 380, Overland Park, KS 66210</p>
			</div>
		</section>

		<Footer />
	</body>
</html>

<style>
	.page-hero {
		background: var(--slate-900);
		color: var(--white);
		padding: 4rem 0;
	}
	.page-hero .section-label {
		color: var(--teal-400);
		font-weight: 600;
		font-size: 0.875rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 0.5rem;
	}
	.page-hero h1 { color: var(--white); margin-bottom: 0.5rem; }
	.page-hero-desc { color: var(--slate-400); font-size: 1.25rem; margin: 0; }

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 4rem;
		align-items: start;
	}
	.contact-info h2 {
		margin-bottom: 1rem;
	}
	.contact-info > p {
		color: var(--text-secondary);
		line-height: 1.7;
		margin-bottom: 2rem;
	}

	.info-cards {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 2.5rem;
	}
	.info-card {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		padding: 1rem;
		background: var(--bg-secondary);
		border-radius: 10px;
		border: 1px solid var(--border);
	}
	.info-icon {
		color: var(--accent);
		flex-shrink: 0;
		margin-top: 2px;
	}
	.info-card strong {
		display: block;
		font-size: 0.8125rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--text-muted);
		margin-bottom: 0.25rem;
	}
	.info-card a {
		font-weight: 600;
		color: var(--text-primary);
	}
	.info-card a:hover { color: var(--accent); }
	.info-card p {
		margin: 0;
		color: var(--text-primary);
		font-weight: 500;
	}

	.office-hours h3 {
		font-size: 1.125rem;
		margin-bottom: 1rem;
	}
	.hours-grid {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 0.5rem 2rem;
		font-size: 0.9375rem;
		color: var(--text-secondary);
	}
	.hours-note {
		font-size: 0.8125rem;
		color: var(--text-muted);
		margin-top: 1rem;
	}

	.form-card {
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: 16px;
		padding: 2.5rem;
	}
	.form-card h3 {
		font-size: 1.375rem;
		margin-bottom: 0.5rem;
	}
	.form-note {
		color: var(--text-muted);
		font-size: 0.875rem;
		margin-bottom: 2rem;
	}
	.form-group {
		margin-bottom: 1.25rem;
	}
	.form-group label {
		display: block;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--text-primary);
		margin-bottom: 0.5rem;
	}
	.form-group input,
	.form-group select,
	.form-group textarea {
		width: 100%;
		padding: 0.75rem 1rem;
		border: 1px solid var(--border);
		border-radius: 8px;
		font-size: 1rem;
		font-family: inherit;
		background: var(--white);
		color: var(--text-primary);
		transition: border-color 0.2s ease;
	}
	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--accent);
		box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1);
	}
	.form-group textarea {
		resize: vertical;
	}
	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.map-section {
		border-top: 1px solid var(--border);
	}
	.map-placeholder {
		background: var(--slate-100);
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 4rem 1.5rem;
		color: var(--slate-400);
		gap: 1rem;
		text-align: center;
	}
	.map-placeholder p {
		font-size: 0.9375rem;
		margin: 0;
	}

	@media (max-width: 768px) {
		.contact-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.form-card { padding: 1.5rem; }
		.form-row { grid-template-columns: 1fr; }
	}
</style>

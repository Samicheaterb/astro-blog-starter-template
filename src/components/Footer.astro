---
import { SITE_TITLE, SITE_PHONE, SITE_EMAIL, SITE_ADDRESS } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-grid">
			<div class="footer-brand">
				<div class="footer-logo">
					<div class="logo-mark">S</div>
					<span class="logo-text">{SITE_TITLE}</span>
				</div>
				<p class="footer-tagline">Compassionate, evidence-based psychological care for individuals and first responders.</p>
			</div>
			<div class="footer-col">
				<h4>Quick Links</h4>
				<ul>
					<li><a href="/">Home</a></li>
					<li><a href="/about">About Dr. Stuteville</a></li>
					<li><a href="/services">Services</a></li>
					<li><a href="/first-responders">First Responders</a></li>
					<li><a href="/contact">Contact</a></li>
				</ul>
			</div>
			<div class="footer-col">
				<h4>Contact</h4>
				<ul>
					<li><a href="tel:{SITE_PHONE}">{SITE_PHONE}</a></li>
					<li><a href="mailto:{SITE_EMAIL}">{SITE_EMAIL}</a></li>
					<li>{SITE_ADDRESS}</li>
				</ul>
			</div>
		</div>
		<div class="footer-bottom">
			<p>&copy; {today.getFullYear()} {SITE_TITLE}, LLC. All rights reserved.</p>
			<div class="footer-links">
				<a href="/contact">Privacy Policy</a>
				<span class="divider">|</span>
				<a href="https://www.linkedin.com/in/taylor-stuteville-2a7720126/" target="_blank" rel="noopener">LinkedIn</a>
			</div>
		</div>
	</div>
</footer>

<style>
	footer {
		background: var(--slate-900);
		color: var(--slate-400);
		padding: 4rem 0 0;
	}
	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}
	.footer-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr 1fr;
		gap: 3rem;
		padding-bottom: 3rem;
		border-bottom: 1px solid var(--slate-800);
	}
	.footer-logo {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}
	.logo-mark {
		width: 40px;
		height: 40px;
		background: var(--accent);
		color: var(--white);
		border-radius: 8px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 700;
		font-size: 1.25rem;
	}
	.logo-text {
		color: var(--white);
		font-weight: 700;
		font-size: 1.25rem;
	}
	.footer-tagline {
		color: var(--slate-400);
		font-size: 0.9375rem;
		line-height: 1.6;
	}
	.footer-col h4 {
		color: var(--white);
		font-size: 1rem;
		margin-bottom: 1rem;
		letter-spacing: 0;
	}
	.footer-col ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.footer-col li {
		margin-bottom: 0.5rem;
		font-size: 0.9375rem;
		line-height: 1.6;
	}
	.footer-col a {
		color: var(--slate-400);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.footer-col a:hover {
		color: var(--teal-400);
	}
	.footer-bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.5rem 0;
		font-size: 0.875rem;
	}
	.footer-bottom p { margin: 0; }
	.footer-links {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.footer-links a {
		color: var(--slate-400);
		text-decoration: none;
	}
	.footer-links a:hover { color: var(--teal-400); }
	.divider { color: var(--slate-700); }

	@media (max-width: 768px) {
		.footer-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.footer-bottom {
			flex-direction: column;
			gap: 0.75rem;
			text-align: center;
		}
	}
</style>
